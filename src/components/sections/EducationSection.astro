---
import type { EducationItem } from '../../data/portfolio';

interface Props {
  items: EducationItem[];
  title: string;
}

const { items, title } = Astro.props;
---

<section id="educacion">
  <h2>{title}</h2>
  <div class="education-list">
    {
      items.map((item, index) => (
        <article class="education-item">
          <span class="education-index">0{index + 1}</span>
          <div class="education-content">
            <h3>{item.degree}</h3>
            <p>{item.institution}</p>
          </div>
          <span class="education-period">{item.period}</span>
        </article>
      ))
    }
  </div>
</section>

<style>
  section {
    margin-bottom: 4rem;
  }

  h2 {
    font-size: 2rem;
    margin-bottom: 2rem;
    text-align: center;
  }

  .education-list {
    display: grid;
    gap: 0.95rem;
    max-width: 860px;
    margin: 0 auto;
    position: relative;
    padding-left: 1.9rem;
  }

  .education-list::before {
    content: '';
    position: absolute;
    left: 0.52rem;
    top: 0.1rem;
    bottom: 0.1rem;
    width: 2px;
    background: linear-gradient(
      180deg,
      rgba(var(--accent), 0.85),
      rgba(var(--accent-2), 0.2)
    );
  }

  .education-item {
    position: relative;
    display: flex;
    justify-content: space-between;
    gap: 0.8rem;
    align-items: baseline;
    background: linear-gradient(
      165deg,
      rgba(var(--surface), 0.98),
      rgba(var(--surface), 0.92)
    );
    border-radius: 16px;
    border: 1px solid rgba(var(--line), 0.14);
    padding: 1rem 1.15rem;
    box-shadow: var(--shadow-elevation-1);
    transition: transform 0.22s ease, box-shadow 0.22s ease, border-color 0.22s ease;
  }

  .education-item:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-elevation-2);
    border-color: rgba(var(--accent), 0.34);
  }

  .education-item::before {
    content: '';
    position: absolute;
    left: -1.38rem;
    top: 1.12rem;
    width: 11px;
    height: 11px;
    border-radius: 50%;
    background: rgb(var(--accent));
    box-shadow: 0 0 0 5px rgba(var(--accent), 0.14);
  }

  .education-index {
    font-size: 0.74rem;
    color: rgba(var(--text), 0.6);
    font-weight: 700;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    min-width: 2.2rem;
    align-self: flex-start;
    padding-top: 0.3rem;
  }

  .education-content {
    flex: 1;
  }

  .education-item h3 {
    margin: 0;
    font-size: 1.08rem;
  }

  .education-item p {
    margin: 0.32rem 0 0;
    color: rgba(var(--text), 0.75);
  }

  .education-period {
    color: rgb(var(--accent));
    background-color: rgba(var(--accent), 0.1);
    border: 1px solid rgba(var(--accent), 0.25);
    border-radius: 999px;
    padding: 0.34rem 0.68rem;
    font-weight: 700;
    font-size: 0.78rem;
    letter-spacing: 0.03em;
    white-space: nowrap;
  }

  @media (max-width: 720px) {
    .education-list {
      padding-left: 1.35rem;
    }

    .education-list::before {
      left: 0.3rem;
    }

    .education-item {
      flex-direction: column;
      align-items: flex-start;
    }

    .education-item::before {
      left: -1.07rem;
    }

    .education-index {
      min-width: auto;
      padding-top: 0;
      margin-bottom: 0.1rem;
    }
  }
</style>
