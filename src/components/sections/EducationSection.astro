---
import type { EducationItem } from '../../data/portfolio';

interface Props {
  items: EducationItem[];
  title: string;
}

const { items, title } = Astro.props;
---

<section id="educacion">
  <h2>{title}</h2>
  <div class="education-list">
    {
      items.map((item) => (
        <article class="education-item">
          <div>
            <h3>{item.degree}</h3>
            <p>{item.institution}</p>
          </div>
          <span>{item.period}</span>
        </article>
      ))
    }
  </div>
</section>

<style>
  section {
    margin-bottom: 4rem;
  }

  h2 {
    font-size: 2rem;
    margin-bottom: 2rem;
    text-align: center;
  }

  .education-list {
    display: grid;
    gap: 1rem;
  }

  .education-item {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    align-items: baseline;
    background-color: rgb(var(--surface));
    border-radius: 12px;
    padding: 1rem 1.25rem;
    box-shadow: var(--shadow-elevation-1);
  }

  .education-item h3 {
    margin: 0;
    font-size: 1.1rem;
  }

  .education-item p {
    margin: 0.3rem 0 0;
    color: rgba(var(--text), 0.75);
  }

  .education-item span {
    color: rgba(var(--text), 0.8);
    font-weight: 600;
    white-space: nowrap;
  }

  @media (max-width: 720px) {
    .education-item {
      flex-direction: column;
      align-items: flex-start;
    }
  }
</style>
