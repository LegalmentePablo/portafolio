---
import type { CaseStudyItem } from '../../data/portfolio';

interface Props {
  items: CaseStudyItem[];
  title: string;
  roleLabel: string;
  stackLabel: string;
  pageLabel: string;
  demoLabel: string;
}

const { items, title, roleLabel, stackLabel, pageLabel, demoLabel } = Astro.props;
---

<section id="casos">
  <h2>{title}</h2>
  <div class="cases-grid">
    {
      items.map((item) => (
        <article class="case-card">
          <h3>{item.title}</h3>
          <p>{item.problem}</p>
          <p><strong>{roleLabel}:</strong> {item.role}</p>
          <p><strong>{stackLabel}:</strong> {item.stack.join(', ')}</p>
          <ul>
            {item.outcomes.map((outcome) => <li>{outcome}</li>)}
          </ul>
          <div class="case-links">
            {item.repoUrl && <a href={item.repoUrl} target="_blank" rel="noopener noreferrer">{pageLabel}</a>}
            {item.demoUrl && <a href={item.demoUrl} target="_blank" rel="noopener noreferrer">{demoLabel}</a>}
          </div>
        </article>
      ))
    }
  </div>
</section>

<style>
  section {
    margin-bottom: 4rem;
  }

  h2 {
    font-size: 2rem;
    margin-bottom: 2rem;
    text-align: center;
  }

  .cases-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 1.5rem;
  }

  .case-card {
    background-color: rgb(var(--surface));
    border-radius: 12px;
    padding: 1.25rem;
    box-shadow: var(--shadow-elevation-1);
  }

  .case-card h3 {
    margin-top: 0;
    color: rgb(var(--accent));
  }

  .case-card p {
    margin: 0.65rem 0;
    line-height: 1.45;
  }

  .case-card ul {
    margin: 0.8rem 0 0;
    padding-left: 1rem;
  }

  .case-links {
    margin-top: 1rem;
    display: flex;
    gap: 0.75rem;
  }

  .case-links a {
    color: rgb(var(--accent));
    text-decoration: none;
    font-weight: 600;
  }

  .case-links a:hover {
    text-decoration: underline;
  }
</style>
