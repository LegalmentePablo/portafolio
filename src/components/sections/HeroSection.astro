---
interface Props {
  title: string;
  highlight: string;
  badgeLabel: string;
  subtitle: string;
  valueProposition: string;
  location: string;
  primaryCta: {
    label: string;
    href: string;
    icon: string;
  };
  secondaryCta: {
    label: string;
    href: string;
    icon: string;
  };
}

const { title, highlight, badgeLabel, subtitle, valueProposition, location, primaryCta, secondaryCta } = Astro.props;
---

<section id="inicio" class="hero">
  {badgeLabel && <span class="hero-badge">{badgeLabel}</span>}
  <h1>
    {title} <span class="highlight">{highlight}</span>
  </h1>
  <p class="subtitle">{subtitle}</p>
  <p class="value">{valueProposition}</p>
  <p class="location">
    <span aria-hidden="true">●</span>
    {location}
  </p>
  <div class="hero-cta">
    <a href={primaryCta.href} target="_blank" rel="noopener noreferrer" class="cta primary">
      <span class="cta-icon" style={`--icon-url: url('${primaryCta.icon}')`} aria-hidden="true"></span>
      {primaryCta.label}
    </a>
    <a href={secondaryCta.href} target="_blank" rel="noopener noreferrer" class="cta secondary">
      <span class="cta-icon" style={`--icon-url: url('${secondaryCta.icon}')`} aria-hidden="true"></span>
      {secondaryCta.label}
    </a>
  </div>
</section>

<style>
  .hero {
    text-align: center;
    padding: 2.3rem 0 3.8rem;
    position: relative;
    isolation: isolate;
  }

  .hero::before {
    content: '';
    position: absolute;
    width: min(740px, 92vw);
    height: 320px;
    left: 50%;
    top: 0.3rem;
    transform: translateX(-50%);
    border-radius: 999px;
    background: linear-gradient(
      120deg,
      rgba(var(--accent), 0.18),
      rgba(var(--accent-2), 0.12)
    );
    filter: blur(42px);
    z-index: -1;
  }

  @media (max-width: 900px) {
    .hero {
      padding: 1.75rem 0 2.85rem;
    }
  }

  .hero-badge {
    display: inline-flex;
    align-items: center;
    border: 1px solid rgba(var(--accent), 0.33);
    background-color: rgba(var(--accent), 0.11);
    color: rgb(var(--accent));
    border-radius: 999px;
    padding: 0.42rem 0.88rem;
    font-size: 0.79rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    margin-bottom: 0.95rem;
  }

  h1 {
    font-size: clamp(2.2rem, 6vw, 3.55rem);
    font-weight: 700;
    margin-bottom: 0.75rem;
    line-height: 1.06;
  }

  .highlight {
    color: rgb(var(--accent));
  }

  .subtitle {
    margin: 0 auto;
    max-width: 760px;
    font-size: clamp(1rem, 2.25vw, 1.22rem);
  }

  .value {
    max-width: 760px;
    margin: 0.95rem auto 0;
    line-height: 1.5;
    color: rgb(var(--muted));
  }

  .location {
    margin-top: 0.72rem;
    color: rgba(var(--text), 0.78);
    font-weight: 600;
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    border: 1px solid rgba(var(--line), 0.16);
    padding: 0.32rem 0.75rem;
    border-radius: 999px;
    background-color: rgba(var(--surface), 0.8);
  }

  .hero-cta {
    margin-top: 1.35rem;
    display: flex;
    justify-content: center;
    gap: 0.8rem;
    flex-wrap: wrap;
  }

  .cta {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    border-radius: 999px;
    padding: 0.74rem 1.18rem;
    border: 1px solid transparent;
    text-decoration: none;
    font-weight: 600;
    transition: transform 0.2s ease, box-shadow 0.2s ease, border-color 0.2s ease;
  }

  .cta:hover {
    transform: translateY(-2px);
  }

  .cta-icon {
    width: 16px;
    height: 16px;
    display: inline-block;
    background-color: currentColor;
    -webkit-mask-image: var(--icon-url);
    mask-image: var(--icon-url);
    -webkit-mask-repeat: no-repeat;
    mask-repeat: no-repeat;
    -webkit-mask-position: center;
    mask-position: center;
    -webkit-mask-size: contain;
    mask-size: contain;
  }

  .cta.primary {
    background: linear-gradient(120deg, rgb(var(--accent)), rgb(var(--accent-2)));
    color: #ffffff;
    box-shadow: 0 10px 22px rgba(var(--accent), 0.33);
  }

  .cta.secondary {
    background-color: rgba(var(--surface), 0.9);
    color: rgb(var(--text));
    border-color: rgba(var(--line), 0.2);
  }

  .cta.secondary:hover {
    border-color: rgba(var(--accent), 0.46);
  }
</style>
