---
import type { ProjectItem } from '../../data/portfolio';

interface Props {
  items: ProjectItem[];
  title: string;
  ctaLabel: string;
  projectTagLabel: string;
}

const { items, title, ctaLabel, projectTagLabel } = Astro.props;
---

<section id="proyectos">
  <h2>{title}</h2>
  <div class="project-grid">
    {
      items.map((project, index) => (
        <article class="project-card">
          <span class="project-index">0{index + 1}</span>
          <span class="project-tag">{projectTagLabel}</span>
          <h3>{project.title}</h3>
          <p>{project.description}</p>
          <a href={project.href} target="_blank" rel="noopener noreferrer" class="project-link">
            {ctaLabel}
          </a>
        </article>
      ))
    }
  </div>
</section>

<style>
  section {
    margin-bottom: 4rem;
  }

  h2 {
    font-size: 2rem;
    margin-bottom: 2rem;
    text-align: center;
  }

  .project-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(270px, 1fr));
    gap: 1.2rem;
  }

  .project-card {
    position: relative;
    background: linear-gradient(
      165deg,
      rgba(var(--surface), 0.98),
      rgba(var(--surface), 0.92)
    );
    border: 1px solid rgba(var(--line), 0.14);
    border-radius: 16px;
    padding: 1.35rem;
    box-shadow: var(--shadow-elevation-1);
    transition: transform 0.22s ease, box-shadow 0.22s ease, border-color 0.22s ease;
  }

  .project-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-elevation-2);
    border-color: rgba(var(--accent), 0.36);
  }

  .project-card::before {
    content: '';
    position: absolute;
    left: 1.35rem;
    right: 1.35rem;
    top: 0.8rem;
    height: 3px;
    border-radius: 999px;
    background: linear-gradient(90deg, rgb(var(--accent)), rgb(var(--accent-2)));
    opacity: 0.7;
  }

  .project-index {
    display: inline-flex;
    margin-top: 0.45rem;
    margin-bottom: 0.8rem;
    color: rgba(var(--text), 0.62);
    font-size: 0.78rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .project-tag {
    display: inline-block;
    margin-bottom: 0.8rem;
    font-size: 0.75rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    font-weight: 700;
    color: rgb(var(--accent));
    background-color: rgba(var(--accent), 0.12);
    border-radius: 999px;
    padding: 0.3rem 0.65rem;
  }

  .project-card h3 {
    margin: 0;
    font-size: 1.18rem;
  }

  .project-card p {
    margin: 0.75rem 0 0;
    color: rgba(var(--text), 0.8);
    line-height: 1.5;
  }

  .project-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    margin-top: 1.05rem;
    color: rgb(var(--text));
    border: 1px solid rgba(var(--line), 0.2);
    border-radius: 999px;
    padding: 0.5rem 0.95rem;
    text-decoration: none;
    font-weight: 600;
    background-color: rgba(var(--surface), 0.65);
  }

  .project-link:hover {
    border-color: rgba(var(--accent), 0.48);
    color: rgb(var(--accent));
  }
</style>
